# Copiar a .env y completar con tus claves.
OPENAI_API_KEY=sk-...
# Opcional: sin esta clave, web_search queda deshabilitada.
TAVILY_API_KEY=tvly-...
# Opcionales:
# OPENAI_MODEL=gpt-4o
# AGENT_WORKSPACE=./workspace
# Observabilidad con Langfuse (opcional): sin estas claves, la instrumentación
# degrada a no-op y el agente corre igual que antes.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
